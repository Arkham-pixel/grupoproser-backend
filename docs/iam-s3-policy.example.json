{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "GrupoProserMediaBucketAccess",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::grupoproser-media-storage-2026-505241659902-us-east-2-an"
    },
    {
      "Sid": "GrupoProserMediaObjectAccess",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:AbortMultipartUpload"
      ],
      "Resource": "arn:aws:s3:::grupoproser-media-storage-2026-505241659902-us-east-2-an/*"
    }
  ]
}
