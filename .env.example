# =============================================================================
# Grupo Proser — backend
# Copiar a .env (mismo directorio) y rellenar. No commitear .env.
# =============================================================================

# --- Entorno y servidor ---
# development | production
NODE_ENV=development
# Puerto HTTP del API (por defecto en código: 3000)
PORT=3000

# --- JWT (firma de tokens) ---
# Obligatorio si NODE_ENV=production. En desarrollo, si falta, el servidor
# arranca con un secreto local (solo para pruebas en máquina).
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# --- MongoDB ---
# Cadena de conexión (Atlas, local, etc.). El servidor exige MONGO_URI.
# Si alguna vez quedó expuesta en git: rotar usuario/contraseña en Atlas y actualizar aquí.
MONGO_URI=mongodb://127.0.0.1:27017/grupoproser
# Base secundaria (SecurUser, etc.). Opcional si no usas ese flujo.
SECONDARY_DB_URI=
# (opcional) Conexión directa SRV en scripts; ver scripts masivos
# MONGO_URI_DIRECT=
# (opcional) DNS personalizado, lista separada por comas
# MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1
# (opcional) 1 = no tocar resolv.conf DNS en scripts
# MONGO_SKIP_PUBLIC_DNS=0

# --- CORS (orígenes explícitos) ---
# Siempre permitidos en código (config/platformUrls.js):
#   https://arnald.grupoproser.com.co (Arnald — principal y respaldo vía DNS)
#   https://aplicacion.grupoproser.com.co (legacy PM2)
# También se usa FRONTEND_URL si está definida.
# Múltiples URLs extra en CORS_ORIGIN o ALLOWED_ORIGINS, separadas por comas.
# CORS_ORIGIN=https://otro-front.com
#
# --- Coolify: copiar las MISMAS variables en principal (52.20.220.24) y respaldo (18.119.83.81) ---
# NODE_ENV=production
# FRONTEND_URL=https://arnald.grupoproser.com.co
# BASE_URL=https://arnaldbackend.grupoproser.com.co
# STORAGE_DRIVER=s3  (+ AWS_* abajo). Sin volumen persistente para uploads en el contenedor.

# --- HTTP endurecido (Helmet + límite en login) ---
# Tras Nginx en producción el trust proxy suele ser correcto; API sin proxy:
# TRUST_PROXY=false
# Emergencia si algo falla: desactiva solo el rate limit en login
# RATE_LIMIT_DISABLED=true
# Ventana y máximo de POST login por IP (defecto: 15 min, 150 intentos)
# RATE_LIMIT_LOGIN_WINDOW_MS=900000
# RATE_LIMIT_LOGIN_MAX=150

# --- Correo (recuperación de contraseña, notificaciones, alertas) ---
# Gmail / Google Workspace: use contraseña de aplicación (16 caracteres), NO la clave de inicio de sesión.
# Tras cambiar .env en producción: pm2 restart grupo-proser-backend
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASS=
# Remitente visible (opcional; por defecto EMAIL_USER)
# EMAIL_FROM=noreply@proserpuertos.com.co
# EMAIL_FROM_NAME=Grupo Proser
# SMTP explícito (opcional; si SMTP_HOST está definido, ignora EMAIL_SERVICE)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# Reintentos al enviar (fallos de red)
# EMAIL_RETRY_ATTEMPTS=3
# Cola en MongoDB si falla el envío (reintento cada 5 min)
# EMAIL_OUTBOX_ENABLED=true
# EMAIL_OUTBOX_CRON=*/5 * * * *
# URL pública del front (enlaces en correos). Producción Arnald:
# FRONTEND_URL=https://arnald.grupoproser.com.co
FRONTEND_URL=http://localhost:5173
# (opcional) Si el front no usa puerto estándar en la misma máquina
# FRONTEND_PORT=5173
# Base pública del API (emails, fallbacks). Producción Arnald:
# BASE_URL=https://arnaldbackend.grupoproser.com.co
BASE_URL=http://localhost:3000
# BACKEND_URL=http://localhost:3000

# --- OpenAI (ChatGPT en rutas /api/chatgpt) ---
OPENAI_API_KEY=
# Modelo por defecto si no se especifica
OPENAI_MODEL=gpt-3.5-turbo

# --- Cron (por defecto activos salvo que pongas =false) ---
# Expresión cron (minuto hora día mes día-semana). Ejemplo: 0 9 * * * = 09:00 diario
ALERTAS_CRON_SCHEDULE=0 9 * * *
ENABLE_ALERTAS_CRON=true
CAMBIO_ESTADOS_CRON_SCHEDULE=0 2 * * *
ENABLE_CAMBIO_ESTADOS_CRON=true

# --- Almacenamiento de archivos (S3 — local y producción) ---
# Obligatorio en ambos entornos para que MongoDB guarde rutas s3: y no /uploads/
# STORAGE_DRIVER=s3
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=
# AWS_S3_KEY_PREFIX=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# URL pública (CloudFront). Si vacío: URLs firmadas temporales
# AWS_S3_PUBLIC_BASE_URL=
# AWS_S3_SIGNED_URL_EXPIRES=3600
# Con S3: seguir sirviendo archivos antiguos en disco local
# STORAGE_SERVE_LEGACY_LOCAL_UPLOADS=true

# --- Scripts de mantenimiento (solo si usas esos scripts) ---
# crear_usuarios.js (seed local): contraseñas solo por env, nunca en código
# SEED_PASSWORD_ADMIN=
# SEED_PASSWORD_SOPORTE=
# SEED_PASSWORD_USUARIO=
# SKIP_CONFIRMATION=true
# ARCHIVO_EXCEL=casos_riesgo.xlsx
# CAMPO_UNICO=nmroRiesgo
# DRY_RUN=true
# BORRAR_ANTIGUOS=false
